# MCP server runtime
MCP_SERVER_NAME=MySQL News MCP
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_TRANSPORT=streamable-http
MCP_AUTH_ENABLED=0
MCP_BASE_URL=

# MySQL source on VPS
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace_me
MYSQL_DATABASE=news
MYSQL_CONNECT_TIMEOUT=8
MYSQL_READ_TIMEOUT=15

# Query guardrails
MCP_MAX_ROWS=1200
MCP_MAX_SCAN_SYMBOLS=50

# OAuth resource-server settings (only required when MCP_AUTH_ENABLED=1)
AUTH_ISSUER_URL=
AUTH_JWKS_URI=
AUTH_AUDIENCE=
AUTH_REQUIRED_SCOPES=news.read
